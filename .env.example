# ── Base de données ───────────────────────────────────────────────────────────
DB_NAME=codflow
DB_USERNAME=codflow
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING
JWT_EXPIRATION=86400000        # 24h en ms
JWT_REFRESH_EXPIRATION=604800000  # 7 jours en ms

# ── CORS (URL du frontend React + sites vitrines) ────────────────────────────
# Liste séparée par virgules ; inclure le back-office CODflow ET les sites vitrines
# (CASTELLO) qui appellent les endpoints /api/v1/public/**.
CORS_ORIGINS=https://YOUR_DOMAIN,https://castello.ma

# ── Site vitrine CASTELLO (API publique) ─────────────────────────────────────
# Clé partagée entre CODflow-back et le site CASTELLO (Next.js).
# Générer avec: openssl rand -hex 32
# Cette clé doit être envoyée par CASTELLO dans l'en-tête `X-API-Key` sur
# chaque appel à /api/v1/public/**. Si vide, les endpoints publics renvoient 503.
CASTELLO_API_KEY=

# ── Mail (optionnel) ─────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Ozon Express (optionnel) ─────────────────────────────────────────────────
OZON_CUSTOMER_ID=
OZON_API_KEY=
OZON_BASE_URL=https://api.ozonexpress.ma

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
